@article{Li2015,
abstract = {This study applies wavelet analysis to examine the relationship between the U.S. housing and stockmarkets over the period 1890–2012. Wavelet analysis allows the simultaneous examination of co-movement and causality between the two markets in both the time and frequency domains. Our findings provide robust evidence that co-movement and causality vary across frequencies and evolve over time. Examining market co-movement in the time domain, the twomarkets exhibit positive co-movement over recent decades, except for 1998–2002 when a high negative co-movement emerged. In the frequency domain, the two markets correlate with each other mainly at low frequencies (longer term), except in the second half of the 1900s as well as in 1998–2002, when the two markets correlate at high frequencies (shorter term). In addition, we find that the causal effects between the markets in the frequency domain occur generally at low frequencies (longer term). In the time-domain, the time-varying nature of long-run causalities implies structural changes in the two markets. These findings provide a more complete picture of the relationship between the U.S. real estate and stock markets over time and frequency, offering important implications for policymakers (and practitioners).},
author = {Li, Xiao-lin and Chang, Tsangyao and Miller, Stephen M and Balcilar, Mehmet and Gupta, Rangan},
doi = {10.1016/j.iref.2015.02.028},
file = {:Users/bazilsansom/Documents/2 Central Library/Li et al. - 2015 - The co-movement and causality between the U.S. housing and stock markets in the time and frequency domains.pdf:pdf},
issn = {1059-0560},
journal = {International Review of Economics and Finance},
keywords = {Frequency domain,Housing market,Stock market,Time domain,Wavelet analysis,economics,granger causality,multivariate time series,multivariate time series analysis,multivariate wavelets,partial coherence,partial wavelets analysis,partial wavelets coherence,phase difference,wavelet coherence,wavelets,wavelets - partial analysis,wavelets in economics},
mendeley-tags = {economics,granger causality,multivariate time series,multivariate time series analysis,multivariate wavelets,partial coherence,partial wavelets analysis,partial wavelets coherence,phase difference,wavelet coherence,wavelets,wavelets - partial analysis,wavelets in economics},
pages = {220--233},
