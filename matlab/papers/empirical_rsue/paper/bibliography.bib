@article{Fratantoni2003,
abstract = {We quantify the importance of heterogeneity for monetary policy using a new heterogeneous-agent VAR (HAVAR) model that integrates national monetary/financial markets with regional housing markets via the mortgage rate. Although the HAVAR model has linear regional VARs, its aggregate impulse responses exhibit two nonliniarities; (I) time variation, stemming from aggregation over heterogeneous regions, and (2) state dependence on initial economic condiiions in regions. Thus, monetary policy has "long and variable lags" because monetary transmission depends on the extent and nature of regional heterogeneity, which both vary over time. The model is estimated with data tor U.S. regions from 1986 to 1996 and simulated to show how coastal housing booms might influence the eficacy of monetary policy.},
