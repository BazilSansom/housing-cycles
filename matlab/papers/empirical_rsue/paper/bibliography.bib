@article{Campbell2009,
abstract = {We apply the dynamic Gordon growth model to the housing market in 23 US metropolitan areas, the four Census regions, and the nation from 1975 to 2007. The model allows the rent-price ratio at each date to be split into the expected present discounted values of rent growth, real interest rates, and a housing premium over real rates. We show that housing premia are variable and forecastable and account for a significant fraction of rent-price ratio volatility at the national and local levels, and that covariances among the three components damp fluctuations in rent-price ratios. Thus, explanations of house-price dynamics that focus only on interest rate movements and ignore these covariances can be misleading. These results are similar to those found for stocks and bonds. {\textcopyright} 2009 Elsevier Inc.},
