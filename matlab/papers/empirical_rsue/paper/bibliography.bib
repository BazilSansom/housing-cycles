@article{Bracke2013,
abstract = {This paper analyzes the duration of house price upturns and downturns in the last 40 years for 19 OECD countries. Both upturns and downturns display duration dependence: they are more likely to end as their duration increases. Downturns display also lagged duration dependence: they are less likely to end if the previous upturn was particularly long. These patterns are consistent with a boom-bust view of housing price dynamics, where booms represent departures from fundamentals that are increasingly difficult to sustain and busts serve as readjustment periods. Findings are robust to the inclusion of macroeconomic variables, which allow for the estimation of additional determinants of house price expansions and contractions.},
