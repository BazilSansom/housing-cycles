@article{Evans1991,
abstract = {A number of studies have argued that dividend and stock price data are not consistent with the "market fundamentals" hypothesis, in which prices are given by the present discounted values of expected dividends. These results have often been construed as evidence for the existence of bubbles or fads. A major problem with such arguments (e.g., James Hamilton and Charles Whiteman, 1985) is that apparent evidence for bubbles can be reinterpreted in terms of market fundamentals that are unobserved by the researcher. Behzad T. Diba and Herschel I. Grossman (1984, 1988b) and Hamilton and Charles have recommended the alternative strategy of testing for rational bubbles by investigating the stationarity properties of asset prices and observable fundamentals. This paper shows that the battery of tests is in fact unable to detect an important class of rational bubbles. The point is demonstrated by constructing rational bubbles that appear to be stationary when unit-root tests are applied, even though they are explosive in the relevant sense.},
author = {Evans, George W},
file = {:Users/bazilsansom/Documents/2 Central Library/Evans - 1991 - Pitfalls in Testing for Explosive Bubbles in Asset Prices.pdf:pdf},
journal = {American Economic Review},
keywords = {bubbles - unit root tests,cycles,cycles - empirical tests,cycles and unit roots,housing cycle,methodology,stability analysis,time series analysis},
