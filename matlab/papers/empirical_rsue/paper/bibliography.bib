keywords = {E44,J.E.L. classification: C32,R10,R31.,US,US house prices - regional,US housing markets,global VAR (GVAR).,housing,housing market spillovers,housing markets,monetary policy,regional house prices},
mendeley-tags = {US,US house prices - regional,US housing markets,housing market spillovers,housing markets,regional house prices},
series = {European Central Bank Working Paper Series},
title = {{Regional housing market spillovers in the US: lessons from regional divergences in a common monetary policy setting}},
