@article{Schroder2017,
abstract = {We analyze the properties of order parameters measuring synchronization and phase locking in complex oscillator networks. First, we review network order parameters previously introduced and reveal several shortcomings: none of the introduced order parameters capture all transitions from incoherence over phase locking to full synchrony for arbitrary, finite networks. We then introduce an alternative, universal order parameter that accurately tracks the degree of partial phase locking and synchronization, adapting the tradi- tional definition to account for the network topology and its influence on the phase coherence of the oscillators. We rigorously proof that this order parameter is strictly monotonously increasing with the coupling strength in the phase locked state, directly reflecting the dynamic stability of the network. Furthermore, it indicates the onset of full phase locking by a diverging slope at the critical coupling strength. The order parameter may find applications across systems where different types of synchrony are possible, including biological networks and power grids. Many},
archivePrefix = {arXiv},
arxivId = {arXiv:1704.04130v1},
author = {Schroder, Malte and Timme, Marc and Witthaut, Dirk},
eprint = {arXiv:1704.04130v1},
file = {:Users/bazilsansom/Documents/2 Central Library/Schroder, Timme, Witthaut - 2017 - A universal order parameter for synchrony in networks of limit cycle oscillators.pdf:pdf},
journal = {Chaos: An Interdisciplinary Journal of Nonlinear Science},
keywords = {empirical analysis,methodology,order parameter,synchronisation,syncronisation - empirical},
mendeley-tags = {empirical analysis,methodology,order parameter,synchronisation,syncronisation - empirical},
number = {7},
title = {{A universal order parameter for synchrony in networks of limit cycle oscillators}},
volume = {27},
year = {2017}
}
